# ===========================================
# 平台配置示例
# 复制此文件为 .env 并修改配置值
# ===========================================

# RabbitMQ 连接 URL
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# 数据库配置
# SQLite (默认)
DATABASE_URL=sqlite:///./sunday_agents.db

# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_platform

# MySQL
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/agent_platform

# 数据库初始化模式
# auto_create: 启动时使用 SQLAlchemy create_all() 兜底建表（默认，适合本地开发）
# migrations_only: 仅依赖 Alembic 迁移，不在应用启动时自动建表
DB_INIT_MODE=auto_create
