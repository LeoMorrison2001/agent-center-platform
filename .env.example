# ===========================================
# Platform config example
# Copy this file to .env and adjust values
# ===========================================

# RabbitMQ URL
RABBITMQ_URL=amqp://admin:tcrj%40123456@192.168.10.212:5672/%2Fagent

# Database config
# MySQL (default)
DATABASE_URL=mysql+pymysql://root:tcrj%40123456@192.168.10.212:3306/agent_platform?charset=utf8mb4

# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_platform

# SQLite
# DATABASE_URL=sqlite:///./agent.db

# Database init mode
# auto_create: use SQLAlchemy create_all() at startup as a local fallback
# migrations_only: rely on Alembic only and do not auto-create tables on startup
DB_INIT_MODE=auto_create
