# ===========================================
# Face assessment worker environment example
# Copy this file to .env and fill in real values
# ===========================================

# Model provider: tongyi / ollama
MODEL_PROVIDER=tongyi

# Model settings
MODEL_NAME=qwen3-max
MODEL_TEMPERATURE=0.0

# Tongyi settings
TONGYI_API_KEY=your-tongyi-api-key

# Ollama settings
OLLAMA_BASE_URL=http://127.0.0.1:11434

# RabbitMQ and platform settings
RABBITMQ_URL=amqp://admin:123456@192.168.10.115:5672/%2Fagent
PLATFORM_API_BASE_URL=http://127.0.0.1:3150
