# ===========================================
# 天气智能体配置示例
# 复制此文件为 .env 并填入实际值
# ===========================================

# 模型配置
MODEL_NAME=gemini-2.5-flash
MODEL_TEMPERATURE=0.0

# Google API Key
# 从 https://makersuite.google.com/app/apikey 获取
GOOGLE_API_KEY=your-api-key-here

# RabbitMQ 连接 URL
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
